{
  "name": "playhook-collection",
  "version": "0.1.0",
  "description": "Showcase site for Playhook and a collection of ready-made game.json manifests.",
  "private": true,
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs && esbuild --servedir=dist --serve=8000 --watch"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1"
  }
}
